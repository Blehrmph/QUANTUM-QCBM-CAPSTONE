{
  "_comment": "Interaction features experiment: replace sbytes+Sload with byte_ratio+load_ratio+pkt_ratio, drop Dpkts to keep 13 qubits under AMP",
  "_base": "best_config.json",

  "features": "byte_ratio,load_ratio,pkt_ratio,dbytes,Dload,is_not_tcp,is_int_state,is_con_state",

  "optimizer":         "adam",
  "adam_lr":           0.003,
  "adam_beta1":        0.9,
  "adam_beta2":        0.999,

  "qcbm_iter":         1500,
  "qcbm_layers":       3,
  "qcbm_ensemble":     3,
  "warmstart_layers":  true,

  "n_bins":            4,
  "bits_per_feature":  2,
  "bin_strategy":      "quantile",
  "encoding":          "binary",
  "auto_mixed_precision": true,

  "lambda_contrast":   0.5,
  "contrast_margin":   10.0,
  "laplace_alpha":     1.0,

  "log1p":             true,
  "scaler":            "standard",
  "tail_percentile":   0.99,
  "precision_targets": "0.65,0.70,0.75,0.80",
  "min_recall":        0.30,
  "test_frac":         0.2,
  "val_frac":          0.1,
  "seed":              42
}
