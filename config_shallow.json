{
  "_comment": "Shallow circuit experiment — 1 layer (~80 gate depth) vs best_run 3 layers (~200 gate depth). All preprocessing identical to best_config.json. Goal: test if hardware ROC-AUC recovers with shallower circuit.",

  "input": "datasets/UNSW-NB15_cleaned.csv",
  "features": "sbytes,Sload,dbytes,Dload,Dpkts,is_not_tcp,is_int_state,is_con_state,sttl",
  "mi_top_k": 0,
  "bin_strategy": "anomaly_aware",

  "optimizer":        "spsa",
  "spsa_a":           0.2,
  "spsa_c":           0.1,

  "qcbm_iter":        1000,
  "qcbm_layers":      1,
  "qcbm_ensemble":    5,
  "warmstart_layers": false,

  "n_bins":           4,
  "bits_per_feature": 2,
  "encoding":         "binary",
  "auto_mixed_precision": true,

  "lambda_contrast":  0.8,
  "contrast_margin":  15.0,
  "laplace_alpha":    0.5,

  "log1p":            true,
  "scaler":           "standard",
  "tail_percentile":  0.99,
  "precision_targets": "0.65,0.70,0.75,0.80",
  "min_recall":       0.30,
  "test_frac":        0.2,
  "val_frac":         0.1,
  "seed":             42
}
